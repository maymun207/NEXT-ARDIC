# ============================================================================
# .env.example — Next.js Enterprise Starter — Environment Variables
# ============================================================================
#
# Copy this file to .env.local and fill in the real values:
#
#   cp .env.example .env.local
#
# IMPORTANT: Do NOT commit .env.local — it is already in .gitignore.
#
# ── QUICK START MINIMUM ──────────────────────────────────────────────────────
# These 3 vars are the bare minimum to run the app locally without errors:
#
#   NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA   ← dev key, always passes
#
# ── VERCEL DEPLOYMENT ───────────────────────────────────────────────────────
# All variables below must ALSO be set in Vercel for production:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# Legend:
#   [PUBLIC SAFE]   → NEXT_PUBLIC_ prefix — safe to expose in the browser
#   [SERVER ONLY]   → Never expose these; server-side only
#   [BUILD TIME]    → Used at build time by next build / Vercel build
#
# Required environments:
#   ┌─────────────────────────────────────────┬─────────┬─────────┬─────────┐
#   │ Variable                                │ Prod    │ Preview │ Dev     │
#   ├─────────────────────────────────────────┼─────────┼─────────┼─────────┤
#   │ NEXT_PUBLIC_SITE_NAME                   │    ✓    │    ✓    │    ✓    │
#   │ NEXT_PUBLIC_SITE_URL                    │    ✓    │    ✓    │    ✓    │
#   │ NEXT_PUBLIC_SITE_DESCRIPTION            │    ✓    │    ✓    │    ✓    │
#   │ SMTP_HOST                               │    ✓    │    ✓    │    ✓    │
#   │ SMTP_PORT                               │    ✓    │    ✓    │    ✓    │
#   │ SMTP_SECURE                             │    ✓    │    ✓    │    ✓    │
#   │ SMTP_USER                               │    ✓    │    ✓    │    ✓    │
#   │ SMTP_PASS                               │    ✓    │    ✓    │    ✓    │
#   │ SMTP_FROM                               │    ✓    │    ✓    │    ✓    │
#   │ CONTACT_EMAIL                           │    ✓    │    ✓    │    ✓    │
#   │ SUPABASE_URL                            │    ✓    │    ✓    │    ✓    │
#   │ SUPABASE_SERVICE_ROLE_KEY               │ ✓(enc.) │    ✗    │    ✓    │
#   │ NEXT_PUBLIC_SUPABASE_URL                │    ✓    │    ✓    │    ✓    │
#   │ NEXT_PUBLIC_SUPABASE_ANON_KEY           │    ✓    │    ✓    │    ✓    │
#   │ SUPABASE_DB_URL                         │    ✗    │    ✗    │ local   │
#   │ TURNSTILE_SECRET_KEY                    │    ✓    │    ✓    │    ✓    │
#   │ NEXT_PUBLIC_TURNSTILE_SITE_KEY          │    ✓    │    ✓    │    ✓    │
#   │ FORMSPREE_ENDPOINT                      │    ✓    │    ✓    │    ✓    │
#   │ NEXT_PUBLIC_GA_MEASUREMENT_ID           │    ✓    │    ✗    │    ✗    │
#   │ NEXT_PUBLIC_SENTRY_DSN                  │    ✓    │    ✓    │    ✗    │
#   └─────────────────────────────────────────┴─────────┴─────────┴─────────┘
#
# SECURITY NOTES:
#   - SUPABASE_SERVICE_ROLE_KEY must NOT start with NEXT_PUBLIC_.
#     It must only exist server-side. In Vercel, set as encrypted.
#   - SUPABASE_DB_URL is for local schema management only.
#     Do NOT add it to Vercel. Do NOT commit it.
#   - TURNSTILE_SECRET_KEY must NOT start with NEXT_PUBLIC_.
#   - FORMSPREE_ENDPOINT must NOT start with NEXT_PUBLIC_.
# ============================================================================


# ── 🌐 SITE IDENTITY ─────────────────────────────────────────────────────────
# Used in metadata, Open Graph tags, structured data (schema.org), and the UI.
# [PUBLIC SAFE] — these appear in HTML source code.
NEXT_PUBLIC_SITE_NAME=Your Company Name
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_DESCRIPTION=Your compelling site tagline or meta description here.


# ── 🗄️ SUPABASE DATABASE ─────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL:      Safe for client-side (browser SDK).              [PUBLIC SAFE]
# NEXT_PUBLIC_SUPABASE_ANON_KEY: Public anon key — safe for client-side with RLS. [PUBLIC SAFE]
# SUPABASE_URL:                  Server-side URL (same value, no NEXT_PUBLIC_).    [SERVER ONLY]
# SUPABASE_SERVICE_ROLE_KEY:     Server-only, bypasses RLS. NEVER expose.          [SERVER ONLY]
# SUPABASE_DB_URL:               Direct Postgres — local schema management only.   [SERVER ONLY]
#   Get from: Supabase Dashboard → Settings → Database → Connection string
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres


# ── 📧 CONTACT FORM (SMTP) ───────────────────────────────────────────────────
# Outgoing mail server used by /api/contact and /api/newsletter routes.
# Powered by the EmailService module (src/lib/EmailService.ts).
# [SERVER ONLY] — never expose SMTP credentials client-side.
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=YOUR_SMTP_APP_PASSWORD
SMTP_FROM=noreply@yourdomain.com
CONTACT_EMAIL=contact@yourdomain.com


# ── 🤖 CAPTCHA — Cloudflare Turnstile ───────────────────────────────────────
# Protects the contact form from automated spam.
# Get from: Cloudflare Dashboard → Turnstile
#
# For local development, use the test site key / secret:
#   Site key:   1x00000000000000000000AA  (always passes)
#   Secret key: 1x0000000000000000000000000000000AA  (always passes)
#
# NEXT_PUBLIC_TURNSTILE_SITE_KEY: Client-side — embedded in widget.    [PUBLIC SAFE]
# TURNSTILE_SECRET_KEY:           Server-only — verifies tokens.        [SERVER ONLY]
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY_HERE
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_HERE


# ── 📬 CONTACT FORM PROXY — Formspree ───────────────────────────────────────
# Server-side only — the endpoint is proxied through /api/contact.
# This keeps your Formspree form ID hidden from the browser.
# Get from: Formspree Dashboard → Forms → Integration → Endpoint
# [SERVER ONLY] — no NEXT_PUBLIC_ prefix!
FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID


# ── 🔢 APP VERSION ───────────────────────────────────────────────────────────
# Set automatically in Vercel via buildCommand in vercel.json — do not set manually.
# Locally, defaults to "dev". Shows in <meta name="app-version"> and /api/health.
# [BUILD TIME]
# NEXT_PUBLIC_APP_VERSION=1.0.0


# ── 📊 ANALYTICS — Google Analytics 4 (Optional) ────────────────────────────
# GA4 measurement ID. Only fires after user accepts analytics cookies
# via the CookieConsent banner. Leave empty to disable GA entirely.
# Get from: Google Analytics → Admin → Data Streams → Web → Measurement ID
# [PUBLIC SAFE]
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ── 🚨 ERROR MONITORING — Sentry ─────────────────────────────────────────────
# Tracks production errors and performance. GDPR-compliant:
# PII (cookies, auth headers) is stripped in beforeSend hooks.
#
# NEXT_PUBLIC_SENTRY_DSN: Client+server DSN (safe to expose).     [PUBLIC SAFE]
#   Get from: Sentry Dashboard → Settings → Projects → Client Keys (DSN)
# SENTRY_ORG:             Your Sentry organization slug.           [BUILD TIME]
# SENTRY_PROJECT:         Your Sentry project slug.                [BUILD TIME]
# SENTRY_AUTH_TOKEN:      Auth token for source map upload.        [BUILD TIME]
#   Get from: Sentry Dashboard → Settings → Auth Tokens
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
